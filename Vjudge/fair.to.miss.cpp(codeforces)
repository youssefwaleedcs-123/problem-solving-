#include <iostream>
#include <vector>
using namespace std;
 
int main() {
    
    int a[5];
    int b[4];

    for (int i = 0; i < 5; i++) {
        cin >> a[i];
    }

    for (int i = 0; i < 4; i++) {
        cin >> b[i];
    }

    for (int i = 0; i < 5; i++) {
        int found = 0;
        for (int j = 0; j < 4; j++) {
            if (a[i] == b[j]) {
                found = 1;
            }
        }
        if (found == 0) {
            cout << a[i];
            return 0;
        }
    }
   
 }
