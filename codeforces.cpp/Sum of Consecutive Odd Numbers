#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
#include <numeric>
using namespace std;

int main() {
	int T;
	cin >> T;
	while (T--)
	{
		int X, Y;
		cin >> X >> Y;
		int sum = 0;
		if (X > Y)
		{
			swap(X, Y);
		}

		for (int i = X + 1; i < Y; i++)
		{

			if (i % 2 != 0)
			{

				sum = sum + i;
			}

		}
		cout << sum << "\n";

	}
}
